{
  "version": 2,
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install",
  "nodeVersion": "20.x",
  "env": {
    "SKIP_ENV_VALIDATION": "true"
  },
  "envPrefix": [],
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoJobCancelPreviousOnPush": true
  },
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  }
}
