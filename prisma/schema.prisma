// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

// ============= USER MODELS =============

model User {
  id            String    @id @default(cuid()) @map("_id")
  email         String    @unique
  password      String
  name          String
  role          Role      @default(STUDENT)
  phone         String?
  avatar        String?
  bio           String?
  
  // Relations
  enrollments   Enrollment[]
  examResults   ExamResult[]
  uploads       Upload[]
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

enum Role {
  STUDENT
  ADMIN
}

// NextAuth Session Models
model Account {
  id                 String  @id @default(cuid()) @map("_id")
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id       String   @id @default(cuid()) @map("_id")
  email    String
  token    String   @unique
  expires  DateTime

  @@unique([email, token])
}

// ============= COURSE MODELS =============

model Course {
  id            String    @id @default(cuid()) @map("_id")
  title         String
  description   String
  price         Float
  instructor    String
  duration      Int       // in hours
  category      String
  thumbnail     String?
  
  // Relations
  enrollments   Enrollment[]
  exams         Exam[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([instructor])
}

model Enrollment {
  id            String    @id @default(cuid()) @map("_id")
  userId        String
  courseId      String
  
  // Payment Info
  paymentStatus PaymentStatus @default(PENDING)
  bkashNumber   String
  transactionId String
  paymentProof  String
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  enrolledAt    DateTime  @default(now())
  verifiedAt    DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([paymentStatus])
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ============= EXAM MODELS =============

model Exam {
  id              String    @id @default(cuid()) @map("_id")
  courseId        String
  title           String
  description     String?
  duration        Int       // in minutes
  totalQuestions  Int
  negativeMarking Float
  passingScore    Float?
  
  // Relations
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions       Question[]
  results         ExamResult[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([courseId])
}

model Question {
  id            String    @id @default(cuid()) @map("_id")
  examId        String
  questionText  String
  options       Option[]
  correctAnswer String    // A, B, C, or D
  order         Int
  
  // Relations
  exam          Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([examId])
}

type Option {
  label String // A, B, C, D
  text  String
}

// ============= RESULT MODELS =============

model ExamResult {
  id              String    @id @default(cuid()) @map("_id")
  userId          String
  examId          String
  
  // Scoring
  totalQuestions  Int
  correctAnswers  Int
  wrongAnswers    Int
  unattempted     Int
  score           Float
  percentage      Float
  negativeMarks   Float
  negativeMarkPercentage Float // (negativeMarks / totalQuestions) * 100
  
  // Time & Status
  timeTaken       Int       // in seconds
  status          ExamStatus @default(COMPLETED)
  
  // Answers (JSON/Object)
  answers         Json      // { questionId: "A", ... }
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam            Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, examId])
  @@index([userId])
  @@index([examId])
  @@index([createdAt])
}

enum ExamStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  GRADED
}

// ============= UPLOAD MODELS =============

model Upload {
  id            String    @id @default(cuid()) @map("_id")
  userId        String
  filename      String
  originalName  String
  fileType      String
  fileSize      Int
  filePath      String
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())

  @@index([userId])
}

// ============= LEADERBOARD MODELS =============

model LeaderboardEntry {
  id            String    @id @default(cuid()) @map("_id")
  userId        String    @unique
  userName      String
  totalScore    Float
  examCount     Int
  avgScore      Float
  rank          Int
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([rank])
  @@index([totalScore])
  @@index([updatedAt])
}
